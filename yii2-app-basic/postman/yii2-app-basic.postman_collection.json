{
	"info": {
		"_postman_id": "b1a1c001-0001-0001-0001-000000000001",
		"name": "yii2-app-basic",
		"description": "Coleção dos endpoints REST do projeto yii2-app-basic.\n\n**Base URL:** `{{baseUrl}}` (http://localhost:8080).\n\n**Envelope padrão:** `{ success, type, data | message }`.\n\n**Variáveis automáticas:** ao criar qualquer recurso, o script de teste captura o `id` retornado e salva em `userId`, `configId`, `profileId` ou `settingId`. As demais requests já usam essas variáveis nos paths.\n\n**Xdebug:** defina `{{xdebugTrigger}}` como `debug123` para ativar o debug em todas as requests (envia `Cookie: XDEBUG_SESSION=debug123`). Deixe vazio para desativar. Requer `xdebug.start_with_request=trigger` e `xdebug.trigger_value=debug123` no php.ini.\n\n**Recursos:**\n- `user-api` — CRUD de usuários + toggle de status.\n- `user-config` — pares key/value por usuário.\n- `user-profile` — dados adicionais do usuário.\n- `user-profile-setting` — settings do profile.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl",        "value": "http://localhost:8080", "type": "string" },
		{ "key": "userId",         "value": "", "type": "string" },
		{ "key": "configId",       "value": "", "type": "string" },
		{ "key": "profileId",      "value": "", "type": "string" },
		{ "key": "settingId",      "value": "", "type": "string" },
		{
			"key": "xdebugTrigger",
			"value": "",
			"type": "string",
			"description": "Deixe vazio para desativar o Xdebug. Defina como 'debug123' para ativar (trigger_value do php.ini). O pre-request script injeta 'Cookie: XDEBUG_SESSION=<valor>' automaticamente."
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Xdebug 3 — start_with_request=trigger",
					"// Quando xdebugTrigger estiver preenchido, injeta o cookie que ativa o debug.",
					"// Configure xdebugTrigger como 'debug123' (ou o valor de xdebug.trigger_value no php.ini).",
					"const trigger = pm.collectionVariables.get('xdebugTrigger');",
					"if (trigger) {",
					"    pm.request.headers.upsert({",
					"        key: 'Cookie',",
					"        value: 'XDEBUG_SESSION=' + trigger",
					"    });",
					"    console.log('[Xdebug] Cookie XDEBUG_SESSION=' + trigger + ' adicionado.');",
					"}"
				]
			}
		}
	],
	"item": [
		{
			"name": "user-api",
			"description": "CRUD do recurso master `users`. GET /:id retorna o user com `configs[]` e `profiles[]` aninhados.",
			"item": [
				{
					"name": "Index — GET /user-api",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user-api",
							"host": ["{{baseUrl}}"],
							"path": ["user-api"]
						},
						"description": "Lista todos os usuários sem filtro."
					}
				},
				{
					"name": "Index com filtros — GET /user-api",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user-api?status=ativo&ordenar_por=name&direcao=asc&limite=10",
							"host": ["{{baseUrl}}"],
							"path": ["user-api"],
							"query": [
								{ "key": "status",      "value": "ativo",    "description": "ativo | inativo" },
								{ "key": "ordenar_por", "value": "name",     "description": "id | name | email | created_at | updated_at" },
								{ "key": "direcao",     "value": "asc",      "description": "asc | desc" },
								{ "key": "limite",      "value": "10",       "description": "Teto de resultados (array_splice)" },
								{ "key": "busca",       "value": "",         "description": "Busca textual em name e email (stripos)", "disabled": true },
								{ "key": "campos[]",    "value": "id",       "description": "Projeção: retorna só os campos listados", "disabled": true },
								{ "key": "campos[]",    "value": "name",     "description": "", "disabled": true },
								{ "key": "coluna",      "value": "email",    "description": "Extrai coluna como array plano (array_column)", "disabled": true },
								{ "key": "ordenacao",   "value": "az",       "description": "az | za — ordena só por name", "disabled": true },
								{ "key": "inverter",    "value": "1",        "description": "Inverte a lista (array_reverse)", "disabled": true },
								{ "key": "sem_dominio", "value": "1",        "description": "Remove domínio do email (array_map + strstr)", "disabled": true },
								{ "key": "resumo",      "value": "1",        "description": "Retorna contagem de ativos/inativos (array_reduce)", "disabled": true },
								{ "key": "chunk",       "value": "3",        "description": "Divide em grupos de N (array_chunk)", "disabled": true },
								{ "key": "pagina",      "value": "1",        "description": "Paginação (array_slice) — use com por_pagina", "disabled": true },
								{ "key": "por_pagina",  "value": "3",        "description": "Itens por página (padrão 3)", "disabled": true }
							]
						},
						"description": "Todos os filtros disponíveis. Habilite/desabilite os query params conforme necessário."
					}
				},
				{
					"name": "Index V2 (ActiveRecord) — GET /user-api/v2",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user-api/v2",
							"host": ["{{baseUrl}}"],
							"path": ["user-api", "v2"]
						},
						"description": "Mesma listagem via ActiveRecord. Benchmark comparativo com o Index padrão (Query Builder)."
					}
				},
				{
					"name": "View — GET /user-api/:id",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user-api/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user-api", "{{userId}}"]
						},
						"description": "Retorna o user com configs[] e profiles[] aninhados."
					}
				},
				{
					"name": "Create — POST /user-api",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const res = pm.response.json();",
									"if (res.success && res.data && res.data.id) {",
									"    pm.collectionVariables.set('userId', res.data.id);",
									"    console.log('userId capturado:', res.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Anderson Lima\",\n    \"email\": \"anderson@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user-api",
							"host": ["{{baseUrl}}"],
							"path": ["user-api"]
						},
						"description": "Cria o user e captura automaticamente o `id` em `{{userId}}`."
					}
				},
				{
					"name": "Update — PUT /user-api/:id",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Anderson Lima Atualizado\",\n    \"email\": \"anderson.novo@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user-api/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user-api", "{{userId}}"]
						}
					}
				},
				{
					"name": "Toggle Active — PATCH /user-api/:id/toggle-active",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user-api/{{userId}}/toggle-active",
							"host": ["{{baseUrl}}"],
							"path": ["user-api", "{{userId}}", "toggle-active"]
						},
						"description": "Alterna is_active entre true e false. Retorna `{ id, is_active, message }`."
					}
				},
				{
					"name": "Delete — DELETE /user-api/:id",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/user-api/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user-api", "{{userId}}"]
						},
						"description": "204 No Content. Remove o user e suas configs/profiles em cascata."
					}
				}
			]
		},
